{
  "expo": {
    "name": "CampusDrop",
    "slug": "campusdrop",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "campusdrop",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#003D1F"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "ng.edu.ui.campusdrop"
    },
    "android": {
      "package": "ng.edu.ui.campusdrop",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#003D1F"
      }
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      "expo-location",
      "expo-updates"
    ],
    "updates": {
      "url": "https://u.expo.dev/campusdrop"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    }
  }
}
